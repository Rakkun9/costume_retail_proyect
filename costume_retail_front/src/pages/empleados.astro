---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Empleados">
  <div class="row g-3 mb-4 align-items-center">
    <div class="col">
      <h2 class="mb-0 fw-bold"><i class="bi bi-person-badge me-2"></i>Gestión de Empleados</h2>
    </div>
  </div>

  <ul class="nav nav-tabs mb-4">
    <li class="nav-item"><button class="nav-link active" data-tab="registrar">Registrar</button></li>
    <li class="nav-item"><button class="nav-link" data-tab="listar">Listar Todos</button></li>
    <li class="nav-item"><button class="nav-link" data-tab="buscar">Buscar por ID</button></li>
  </ul>

  <!-- Registrar -->
  <div id="tab-registrar" class="tab-content-panel">
    <div class="card">
      <div class="card-header bg-warning text-dark">Nuevo Empleado</div>
      <div class="card-body">
        <form id="formEmpleado" class="row g-3">
          <div class="col-md-4">
            <label class="form-label">N° Identificación *</label>
            <input type="text" name="numero_identificacion" class="form-control" required placeholder="CC, NIT..." />
          </div>
          <div class="col-md-4">
            <label class="form-label">Nombre *</label>
            <input type="text" name="nombre" class="form-control" required />
          </div>
          <div class="col-md-4">
            <label class="form-label">Apellido *</label>
            <input type="text" name="apellido" class="form-control" required />
          </div>
          <div class="col-md-4">
            <label class="form-label">Teléfono *</label>
            <input type="tel" name="telefono" class="form-control" required placeholder="Ej: 3001234567" />
          </div>
          <div class="col-md-4">
            <label class="form-label">Email</label>
            <input type="email" name="email" class="form-control" placeholder="correo@ejemplo.com" />
          </div>
          <div class="col-md-4">
            <label class="form-label">Cargo *</label>
            <input type="text" name="cargo" class="form-control" required placeholder="Ej: Vendedor, Gerente..." />
          </div>
          <div class="col-12">
            <button type="submit" class="btn btn-warning">
              <i class="bi bi-person-plus me-2"></i>Registrar Empleado
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Listar -->
  <div id="tab-listar" class="tab-content-panel d-none">
    <div class="card">
      <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
        Todos los Empleados
        <button class="btn btn-sm btn-light" id="btnRefreshEmpleados"><i class="bi bi-arrow-clockwise"></i> Actualizar</button>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead>
              <tr><th>Identificación</th><th>Nombre</th><th>Apellido</th><th>Cargo</th><th>Teléfono</th><th>Email</th></tr>
            </thead>
            <tbody id="tablaEmpleados">
              <tr><td colspan="6" class="text-center text-muted py-3">Cargando...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- Buscar -->
  <div id="tab-buscar" class="tab-content-panel d-none">
    <div class="card mb-3">
      <div class="card-body">
        <div class="row g-2 align-items-end">
          <div class="col-md-5">
            <label class="form-label">Número de Identificación</label>
            <input type="text" id="inputEmpleadoId" class="form-control" placeholder="Ej: 987654321" />
          </div>
          <div class="col-auto">
            <button class="btn btn-warning" id="btnBuscarEmpleado">
              <i class="bi bi-search me-1"></i>Buscar
            </button>
          </div>
        </div>
      </div>
    </div>
    <div id="resultadoEmpleado"></div>
  </div>
</Layout>

<script>
  document.querySelectorAll('[data-tab]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('[data-tab]').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-content-panel').forEach(p => p.classList.add('d-none'));
      btn.classList.add('active');
      document.getElementById(`tab-${btn.dataset.tab}`).classList.remove('d-none');
      if (btn.dataset.tab === 'listar') loadEmpleados();
    });
  });

  document.getElementById('formEmpleado').addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(e.target));
    if (!data.email) delete data.email;
    try {
      const res = await fetch(`${window.API_URL}/empleados`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      const json = await res.json();
      if (!res.ok) throw new Error(json.message || 'Error al registrar');
      window.showToast(`<i class="bi bi-check-circle me-1"></i>Empleado <strong>${json.nombre} ${json.apellido}</strong> registrado exitosamente`);
      e.target.reset();
    } catch (err) {
      window.showToast(`<i class="bi bi-x-circle me-1"></i>${err.message}`, 'danger');
    }
  });

  async function loadEmpleados() {
    try {
      const res = await fetch(`${window.API_URL}/empleados`);
      const empleados = await res.json();
      const tbody = document.getElementById('tablaEmpleados');
      if (!empleados.length) { tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-3">No hay empleados registrados</td></tr>'; return; }
      tbody.innerHTML = empleados.map(emp => `
        <tr>
          <td><code>${emp.numero_identificacion}</code></td>
          <td>${emp.nombre}</td>
          <td>${emp.apellido}</td>
          <td><span class="badge bg-secondary">${emp.cargo}</span></td>
          <td>${emp.telefono}</td>
          <td>${emp.email || '<span class="text-muted">—</span>'}</td>
        </tr>`).join('');
    } catch {
      window.showToast('Error cargando empleados', 'danger');
    }
  }
  document.getElementById('btnRefreshEmpleados').addEventListener('click', loadEmpleados);

  document.getElementById('btnBuscarEmpleado').addEventListener('click', async () => {
    const id = document.getElementById('inputEmpleadoId').value.trim();
    if (!id) return;
    try {
      const res = await fetch(`${window.API_URL}/empleados/${encodeURIComponent(id)}`);
      const emp = await res.json();
      if (!res.ok) throw new Error(emp.message);
      document.getElementById('resultadoEmpleado').innerHTML = `
        <div class="card">
          <div class="card-header bg-light">Datos del Empleado</div>
          <div class="card-body">
            <div class="row g-3">
              <div class="col-6 col-md-3"><small class="text-muted d-block">Identificación</small><strong>${emp.numero_identificacion}</strong></div>
              <div class="col-6 col-md-3"><small class="text-muted d-block">Nombre</small>${emp.nombre}</div>
              <div class="col-6 col-md-3"><small class="text-muted d-block">Apellido</small>${emp.apellido}</div>
              <div class="col-6 col-md-3"><small class="text-muted d-block">Cargo</small>${emp.cargo}</div>
              <div class="col-6 col-md-3"><small class="text-muted d-block">Teléfono</small>${emp.telefono}</div>
              <div class="col-6 col-md-3"><small class="text-muted d-block">Email</small>${emp.email || '—'}</div>
            </div>
          </div>
        </div>`;
    } catch (err) {
      document.getElementById('resultadoEmpleado').innerHTML = `<div class="alert alert-warning">${err.message}</div>`;
    }
  });
</script>
