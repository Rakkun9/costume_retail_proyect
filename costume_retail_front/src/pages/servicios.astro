---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Servicios de Alquiler">
  <div class="row g-3 mb-4 align-items-center">
    <div class="col">
      <h2 class="mb-0 fw-bold"><i class="bi bi-calendar-check me-2"></i>Servicios de Alquiler</h2>
    </div>
  </div>

  <ul class="nav nav-tabs mb-4">
    <li class="nav-item"><button class="nav-link active" data-tab="registrar">Registrar</button></li>
    <li class="nav-item"><button class="nav-link" data-tab="buscar-numero">Por Número</button></li>
    <li class="nav-item"><button class="nav-link" data-tab="buscar-cliente">Por Cliente</button></li>
    <li class="nav-item"><button class="nav-link" data-tab="buscar-fecha">Por Fecha</button></li>
  </ul>

  <!-- Registrar -->
  <div id="tab-registrar" class="tab-content-panel">
    <div class="card">
      <div class="card-header bg-info text-white">Nuevo Servicio de Alquiler</div>
      <div class="card-body">
        <form id="formServicio" class="row g-3">
          <div class="col-md-4">
            <label class="form-label">N° Identificación Cliente *</label>
            <input type="text" name="cliente_id" class="form-control" required placeholder="Debe estar registrado" />
          </div>
          <div class="col-md-4">
            <label class="form-label">N° Identificación Empleado *</label>
            <input type="text" name="empleado_id" class="form-control" required placeholder="Debe estar registrado" />
          </div>
          <div class="col-md-4">
            <label class="form-label">Fecha de Alquiler *</label>
            <input type="date" name="fecha_alquiler" class="form-control" required id="fechaAlquiler" />
          </div>
          <div class="col-12">
            <label class="form-label">Referencias de Prendas *</label>
            <div class="text-muted small mb-2">Añade las referencias de las prendas a alquilar</div>
            <div id="prendasContainer">
              <div class="input-group mb-2">
                <span class="input-group-text"><i class="bi bi-bag"></i></span>
                <input type="text" class="form-control prenda-ref" placeholder="Ej: VEST-001" required />
                <button type="button" class="btn btn-outline-danger btn-remove-prenda" title="Eliminar"><i class="bi bi-trash"></i></button>
              </div>
            </div>
            <button type="button" class="btn btn-outline-secondary btn-sm" id="btnAgregarPrenda">
              <i class="bi bi-plus me-1"></i>Agregar otra prenda
            </button>
          </div>
          <div class="col-12">
            <div class="alert alert-info small mb-0">
              <i class="bi bi-info-circle me-1"></i>
              El número de servicio se genera automáticamente. La fecha de solicitud se captura del sistema.
            </div>
          </div>
          <div class="col-12">
            <button type="submit" class="btn btn-info text-white">
              <i class="bi bi-calendar-plus me-2"></i>Registrar Servicio
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Por Número -->
  <div id="tab-buscar-numero" class="tab-content-panel d-none">
    <div class="card mb-3">
      <div class="card-body">
        <div class="row g-2 align-items-end">
          <div class="col-md-4">
            <label class="form-label">Número del Servicio</label>
            <input type="number" id="inputNumeroServicio" class="form-control" min="1" placeholder="Ej: 1, 2, 3..." />
          </div>
          <div class="col-auto">
            <button class="btn btn-info text-white" id="btnBuscarNumero">
              <i class="bi bi-search me-1"></i>Buscar
            </button>
          </div>
        </div>
      </div>
    </div>
    <div id="resultadoNumero"></div>
  </div>

  <!-- Por Cliente -->
  <div id="tab-buscar-cliente" class="tab-content-panel d-none">
    <div class="card mb-3">
      <div class="card-body">
        <div class="row g-2 align-items-end">
          <div class="col-md-5">
            <label class="form-label">N° Identificación del Cliente</label>
            <input type="text" id="inputClienteServicios" class="form-control" placeholder="Ej: 123456789" />
          </div>
          <div class="col-auto">
            <button class="btn btn-info text-white" id="btnBuscarServiciosCliente">
              <i class="bi bi-search me-1"></i>Buscar
            </button>
          </div>
        </div>
        <div class="text-muted small mt-1">Se muestran servicios con fecha de alquiler igual o posterior a hoy</div>
      </div>
    </div>
    <div id="resultadoServiciosCliente"></div>
  </div>

  <!-- Por Fecha -->
  <div id="tab-buscar-fecha" class="tab-content-panel d-none">
    <div class="card mb-3">
      <div class="card-body">
        <div class="row g-2 align-items-end">
          <div class="col-md-4">
            <label class="form-label">Fecha de Alquiler</label>
            <input type="date" id="inputFechaServicios" class="form-control" />
          </div>
          <div class="col-auto">
            <button class="btn btn-info text-white" id="btnBuscarServiciosFecha">
              <i class="bi bi-search me-1"></i>Buscar
            </button>
          </div>
        </div>
      </div>
    </div>
    <div id="resultadoServiciosFecha"></div>
  </div>
</Layout>

<script>
  // Set min date for rental
  document.getElementById('fechaAlquiler').min = new Date().toISOString().split('T')[0];

  document.querySelectorAll('[data-tab]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('[data-tab]').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-content-panel').forEach(p => p.classList.add('d-none'));
      btn.classList.add('active');
      document.getElementById(`tab-${btn.dataset.tab}`).classList.remove('d-none');
    });
  });

  // Add/remove prenda fields
  document.getElementById('btnAgregarPrenda').addEventListener('click', () => {
    const container = document.getElementById('prendasContainer');
    const div = document.createElement('div');
    div.className = 'input-group mb-2';
    div.innerHTML = `<span class="input-group-text"><i class="bi bi-bag"></i></span><input type="text" class="form-control prenda-ref" placeholder="Ej: VEST-002" required /><button type="button" class="btn btn-outline-danger btn-remove-prenda" title="Eliminar"><i class="bi bi-trash"></i></button>`;
    container.appendChild(div);
    div.querySelector('.btn-remove-prenda').addEventListener('click', () => div.remove());
  });

  document.querySelector('.btn-remove-prenda').addEventListener('click', (e) => {
    const inputs = document.querySelectorAll('.prenda-ref');
    if (inputs.length > 1) e.target.closest('.input-group').remove();
  });

  // Registrar servicio
  document.getElementById('formServicio').addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = {
      cliente_id: e.target.querySelector('[name="cliente_id"]').value.trim(),
      empleado_id: e.target.querySelector('[name="empleado_id"]').value.trim(),
      fecha_alquiler: e.target.querySelector('[name="fecha_alquiler"]').value,
      referencias_prendas: [...document.querySelectorAll('.prenda-ref')].map(i => i.value.trim()).filter(Boolean),
    };
    if (!data.referencias_prendas.length) { window.showToast('Agrega al menos una prenda', 'warning'); return; }
    try {
      const res = await fetch(`${window.API_URL}/servicios`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      const json = await res.json();
      if (!res.ok) throw new Error(Array.isArray(json.message) ? json.message.join(', ') : json.message);
      window.showToast(`<i class="bi bi-check-circle me-1"></i>Servicio #<strong>${json.numero_servicio}</strong> registrado exitosamente`);
      e.target.reset();
      // Reset prenda fields
      const container = document.getElementById('prendasContainer');
      container.innerHTML = `<div class="input-group mb-2"><span class="input-group-text"><i class="bi bi-bag"></i></span><input type="text" class="form-control prenda-ref" placeholder="Ej: VEST-001" required /><button type="button" class="btn btn-outline-danger btn-remove-prenda" title="Eliminar"><i class="bi bi-trash"></i></button></div>`;
      container.querySelector('.btn-remove-prenda').addEventListener('click', (e) => {
        if (document.querySelectorAll('.prenda-ref').length > 1) e.target.closest('.input-group').remove();
      });
    } catch (err) {
      window.showToast(`<i class="bi bi-x-circle me-1"></i>${err.message}`, 'danger');
    }
  });

  function renderServicio(s) {
    return `
      <div class="card mb-3">
        <div class="card-header bg-light d-flex justify-content-between">
          <span><i class="bi bi-hash"></i> Servicio #<strong>${s.numero_servicio}</strong></span>
          <span class="text-muted small">Solicitado: ${new Date(s.fecha_solicitud).toLocaleDateString('es-CO')}</span>
        </div>
        <div class="card-body">
          <div class="row g-3 mb-3">
            <div class="col-md-4">
              <small class="text-muted d-block">Fecha de Alquiler</small>
              <strong>${s.fecha_alquiler}</strong>
            </div>
            <div class="col-md-4">
              <small class="text-muted d-block">Cliente</small>
              ${s.cliente ? `${s.cliente.nombre} ${s.cliente.apellido} <code class="small">${s.cliente.numero_identificacion}</code>` : '—'}
            </div>
            <div class="col-md-4">
              <small class="text-muted d-block">Empleado</small>
              ${s.empleado ? `${s.empleado.nombre} ${s.empleado.apellido} <span class="badge bg-secondary">${s.empleado.cargo}</span>` : '—'}
            </div>
          </div>
          <small class="text-muted d-block mb-1">Prendas alquiladas:</small>
          <div class="d-flex flex-wrap gap-2">
            ${(s.prendas || []).map(p => `<span class="badge bg-primary"><i class="bi bi-bag me-1"></i>${p.referencia} – ${p.nombre} (T: ${p.talla})</span>`).join('') || '<span class="text-muted">Sin prendas</span>'}
          </div>
        </div>
      </div>`;
  }

  // Por número
  document.getElementById('btnBuscarNumero').addEventListener('click', async () => {
    const num = document.getElementById('inputNumeroServicio').value;
    if (!num) return;
    try {
      const res = await fetch(`${window.API_URL}/servicios/${num}`);
      const s = await res.json();
      if (!res.ok) throw new Error(s.message);
      document.getElementById('resultadoNumero').innerHTML = renderServicio(s);
    } catch (err) {
      document.getElementById('resultadoNumero').innerHTML = `<div class="alert alert-warning">${err.message}</div>`;
    }
  });

  // Por cliente
  document.getElementById('btnBuscarServiciosCliente').addEventListener('click', async () => {
    const id = document.getElementById('inputClienteServicios').value.trim();
    if (!id) return;
    try {
      const res = await fetch(`${window.API_URL}/servicios/cliente/${encodeURIComponent(id)}`);
      const data = await res.json();
      if (!res.ok) throw new Error(data.message);
      const div = document.getElementById('resultadoServiciosCliente');
      const c = data.cliente;
      const servicios = data.servicios;
      div.innerHTML = `
        <div class="card mb-3">
          <div class="card-header bg-success text-white">Datos del Cliente</div>
          <div class="card-body">
            <div class="row g-2">
              <div class="col-auto"><strong>${c.nombre} ${c.apellido}</strong></div>
              <div class="col-auto"><code>${c.numero_identificacion}</code></div>
              <div class="col-auto">${c.telefono}</div>
              <div class="col-auto">${c.email || ''}</div>
              <div class="col-auto text-muted">${c.direccion}</div>
            </div>
          </div>
        </div>
        <h6 class="text-muted mb-2">Servicios vigentes (${servicios.length})</h6>
        ${servicios.length ? servicios.map(renderServicio).join('') : '<div class="alert alert-info">No hay servicios vigentes para este cliente</div>'}`;
    } catch (err) {
      document.getElementById('resultadoServiciosCliente').innerHTML = `<div class="alert alert-warning">${err.message}</div>`;
    }
  });

  // Por fecha
  document.getElementById('btnBuscarServiciosFecha').addEventListener('click', async () => {
    const fecha = document.getElementById('inputFechaServicios').value;
    if (!fecha) return;
    try {
      const res = await fetch(`${window.API_URL}/servicios/fecha/${fecha}`);
      const servicios = await res.json();
      if (!res.ok) throw new Error(servicios.message);
      const div = document.getElementById('resultadoServiciosFecha');
      div.innerHTML = `<h6 class="text-muted mb-2">Servicios para el ${fecha} (${servicios.length})</h6>` +
        (servicios.length ? servicios.map(renderServicio).join('') : '<div class="alert alert-info">No hay servicios para esa fecha</div>');
    } catch (err) {
      document.getElementById('resultadoServiciosFecha').innerHTML = `<div class="alert alert-warning">${err.message}</div>`;
    }
  });
</script>
