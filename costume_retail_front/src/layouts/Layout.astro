---
interface Props {
  title?: string;
}
const { title = 'Costume Retail' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Costume Rental</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
    <style>
      body { background-color: #f8f9fa; font-family: 'Segoe UI', system-ui, sans-serif; }
      .navbar-brand { font-weight: 700; }
      .card { border: none; box-shadow: 0 2px 8px rgba(0,0,0,0.08); border-radius: 12px; }
      .card-header { border-radius: 12px 12px 0 0 !important; font-weight: 600; }
      .btn { border-radius: 8px; }
      .table th { background-color: #f1f3f5; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; }
      .alert { border-radius: 10px; }
      #toast-container { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 9999; display: flex; flex-direction: column; gap: 0.5rem; }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
      <div class="container">
        <a class="navbar-brand" href="/">
          <i class="bi bi-suit-heart-fill me-2 text-danger"></i>Costume Rental
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
          <ul class="navbar-nav ms-auto gap-1">
            <li class="nav-item"><a class="nav-link" href="/prendas"><i class="bi bi-bag me-1"></i>Prendas</a></li>
            <li class="nav-item"><a class="nav-link" href="/clientes"><i class="bi bi-people me-1"></i>Clientes</a></li>
            <li class="nav-item"><a class="nav-link" href="/empleados"><i class="bi bi-person-badge me-1"></i>Empleados</a></li>
            <li class="nav-item"><a class="nav-link" href="/servicios"><i class="bi bi-calendar-check me-1"></i>Servicios</a></li>
            <li class="nav-item"><a class="nav-link" href="/lavanderia"><i class="bi bi-droplet me-1"></i>Lavandería</a></li>
          </ul>
        </div>
      </div>
    </nav>

    <div class="container py-4">
      <slot />
    </div>

    <div id="toast-container"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      window.API_URL = (typeof import.meta !== 'undefined' && import.meta.env?.PUBLIC_API_URL) || 'http://localhost:3000/api';

      window.showToast = function(message, type = 'success') {
        const container = document.getElementById('toast-container');
        const toast = document.createElement('div');
        toast.className = `alert alert-${type} alert-dismissible shadow mb-0`;
        toast.style.minWidth = '280px';
        toast.innerHTML = `${message}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
        container.appendChild(toast);
        setTimeout(() => toast.remove(), 4500);
      };

      document.querySelectorAll('.nav-link').forEach(link => {
        const href = link.getAttribute('href');
        if (href === window.location.pathname || (href !== '/' && window.location.pathname.startsWith(href))) {
          link.classList.add('active', 'fw-semibold');
        }
      });
    </script>
  </body>
</html>

